{
  "name": "nearu-api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --out-dir dist --format esm --clean",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "db:migrate": "npx drizzle-kit migrate",
    "db:generate": "npx drizzle-kit generate",
    "db:push": "npx drizzle-kit push",
    "db:studio": "npx drizzle-kit studio",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@evyweb/ioctopus": "^1.4.1",
    "better-auth": "^1.6.22",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "pg": "^8.13.0",
    "resend": "^6.16.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
